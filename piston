#!/usr/bin/env bash

EXECUTION_PATH="$PWD"
PISTON_PATH="$(dirname "$(realpath "$0")")"

cd "$PISTON_PATH"
PISTON_ENV=$(cat .piston_env 2> /dev/null || echo dev)

docker_compose(){
    if [ -f "docker-compose.$PISTON_ENV.yaml" ]; then
        docker-compose -f "docker-compose.$PISTON_ENV.yaml" "$@"
    else
        docker-compose "$@"
    fi
}

case $1 in
    help)
        echo "=== Piston Management ==="
        echo "Current Environment: $PISTON_ENV"
        echo
        echo "Commands:"
        echo " select <environment>           Select the environment"
        echo " docker_compose <args...>       Interact directly with the docker-compose for the selected environment"
        echo " logs                           Show docker-compose logs"
        echo
        echo " setup                          Interactive installation of language packages"
        echo " list                           Lists all registered packages"
        echo " install <packages...>          Installs language packages"
        echo " start                          Starts piston"
        echo " stop                           Stops piston"
        echo " restart                        Restarts piston"
        echo " uninstall <packages...>        Uninstalls language packages"
        echo " bash                           Opens a bash shell for the piston_api container"
        echo
        echo " update                         Fetches and applies latest updates"
        echo
        echo " <args..>                       Passthrough to piston cli tool"
        echo
        echo "Development Commands:"

        if [ "$PISTON_ENV" == dev ]; then

        echo " clean-pkgs                              Clean any package build artifacts on disk"
        echo " clean-repo                              Remove all packages from local repo"
        echo " list-pkgs                               Lists all packages that can be built"
        echo " build-pkg <package> <version> [builder] Build a package [with desired builder image]"
        echo " rebuild                                 Build and restart the docker container"
        echo " lint                                    Lint the codebase using prettier"

        else

        echo " Switch to development environment for more info"
        echo " > piston select dev"

        fi
        ;;

    select) echo "$2" > .piston_env ;;
    docker_compose) shift; docker_compose "$@";;
    logs) docker_compose logs -f ;;

    list)
        shift
        # Ensure CLI is ready
        [ -d ./core/cli/node_modules ] || (cd core/cli && npm i > /dev/null && cd -)
        cd "$EXECUTION_PATH"
        node "${PISTON_PATH}/core/cli/index.js" ppman list "$@"
        ;;

    install)
        shift
        # Ensure CLI is ready
        [ -d ./core/cli/node_modules ] || (cd core/cli && npm i > /dev/null && cd -)
        cd "$EXECUTION_PATH"
        node "${PISTON_PATH}/core/cli/index.js" ppman install "$@"
        ;;

    setup)
        echo "=== Piston Setup Wizard ==="
        echo "Scanning for available language packages..."
        packages=($(find packages -maxdepth 2 | awk -F/ '$2 && $3{ print $2 "-" $3 }' | sort -V))
        
        if [ ${#packages[@]} -eq 0 ]; then
            echo "No packages found in packages/ directory."
            exit 1
        fi

        echo "Available packages:"
        for i in "${!packages[@]}"; do
            printf "[%2d] %s\n" $((i+1)) "${packages[$i]}"
        done

        echo
        echo "Enter selections (e.g., 1,3,5 or shorthand like 'gcc,node,python')."
        echo "Multiple selection: "
        read selection

        indices=()
        items=$(echo "$selection" | tr ',' ' ')

        if [[ "$selection" == "all" ]]; then
            indices=("${!packages[@]}")
        else
            for item in $items; do
                if [[ "$item" =~ ^[0-9]+$ ]]; then
                    indices+=($((item - 1)))
                else
                    matches=()
                    for i in "${!packages[@]}"; do
                        pkg="${packages[$i]}"
                        if [[ "$pkg" == "$item" ]] || [[ "$pkg" == "$item-"* ]]; then
                            matches+=("$i")
                        fi
                    done
                    
                    if [ ${#matches[@]} -gt 0 ]; then
                        last_idx=$(( ${#matches[@]} - 1 ))
                        indices+=("${matches[$last_idx]}")
                    else
                        echo "⚠️  No package found for: $item"
                    fi
                fi
            done
        fi

        unique_indices=($(echo "${indices[@]}" | tr ' ' '\n' | sort -u | tr '\n' ' '))

        if [ ${#unique_indices[@]} -eq 0 ]; then
            echo "No valid packages selected."
            exit 1
        fi

        echo "========================================"
        echo "Starting installation for ${#unique_indices[@]} package(s)..."
        echo "========================================"

        for i in "${unique_indices[@]}"; do
            pkg="${packages[$i]}"
            if [[ -z "$pkg" ]]; then continue; fi

            lang=$(echo "$pkg" | cut -d'-' -f1)
            ver=$(echo "$pkg" | cut -d'-' -f2-)

            echo "📦 Installing $pkg..."
            echo "   [1/3] Ensuring Piston is running..."
            ./piston start > /dev/null 2>&1
            
            echo "   [2/3] Building package (this may take a while)..."
            if ! ./piston build-pkg "$lang" "$ver"; then
                echo "❌ Failed to build $pkg. Check the logs above for details."
                exit 1
            fi
            
            echo "   [3/3] Registering with Piston API..."
            if ! ./piston ppman install "$lang"; then
                echo "❌ Failed to register $pkg with the API."
                exit 1
            fi
            
            echo "✅ $pkg installed successfully!"
            echo
        done

        echo "========================================"
        echo "Setup complete! All selected packages are ready."
        echo "Run './piston list' to verify."
        ;;

    restart) docker_compose restart ;;
    start)
        docker_compose up -d
        ;;
    stop) docker_compose down ;;
    uninstall)
        shift
        # Ensure CLI is ready
        [ -d ./core/cli/node_modules ] || (cd core/cli && npm i > /dev/null && cd -)
        cd "$EXECUTION_PATH"
        node "${PISTON_PATH}/core/cli/index.js" ppman uninstall "$@"
        ;;
    bash) docker_compose exec api /bin/bash ;;

    rebuild)
        docker_compose build && docker_compose up -d
        ;;

    update)
        git pull
        cd core/cli && npm i > /dev/null && cd -
        docker_compose pull
        docker_compose up -d
        ;;

    clean-pkgs) git clean -fqXd packages ;;
    clean-repo) git clean -fqXd core/repo ;;

    list-pkgs) find packages -maxdepth 2 | awk -F/ '$2 && $3{ print $2 "-" $3 }' | column ;;

    build-pkg)
        PKGSLUG="$2-$3"
        BUILDER="${4:-piston-repo-builder}"
        echo "Building $PKGSLUG"
        echo "Ensuring latest builder image"
        docker build core/repo -t "$BUILDER"
        docker run --rm -v "$PWD:/piston" "$BUILDER" --no-server "$PKGSLUG"
        ;;

    lint)
        npm install
        npx prettier --ignore-unknown --write .
        ;;
    *)
        [ -d ./core/cli/node_modules ] || (cd core/cli && npm i > /dev/null && cd -)
        cd "$EXECUTION_PATH"
        node "${PISTON_PATH}/core/cli/index.js" "$@"
        ;;
esac
